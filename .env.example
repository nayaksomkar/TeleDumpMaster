# TeleDumpMaster configuration template.
# Copy this file to `.env` and fill in your values, then run:
#   teledumpmaster            # watch forever
#   teledumpmaster --once     # single scan
#
# NEVER commit your real .env file. It is git-ignored by default.

# --- Required ---
# Your bot token from @BotFather on Telegram.
TELEDUMP_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Target chat or channel ID (e.g. -1001234567890 or @channelname).
TELEDUMP_CHANNEL_ID=YOUR_CHANNEL_ID_HERE

# Folder path to watch for new files.
TELEDUMP_UPLOAD_FOLDER=./uploads

# --- Optional (defaults shown) ---
# Seconds between folder scans.
TELEDUMP_POLL_INTERVAL=5

# Upload attempts before giving up on a file.
TELEDUMP_RETRIES=3

# Per-request timeout in seconds.
TELEDUMP_TIMEOUT=60

# What to do after a successful upload: keep | delete | archive
TELEDUMP_POST_ACTION=keep

# Optional caption sent with every document.
TELEDUMP_CAPTION=

# Where archived files go when TELEDUMP_POST_ACTION=archive.
TELEDUMP_ARCHIVE_DIR=./archive

# Where upload logs are written.
TELEDUMP_LOG_DIR=./logs

# Log format: json | csv | none
TELEDUMP_LOG_FORMAT=json
